---
import PageLayout from '../../../layouts/PageLayout.astro';
import { LobbyScreen } from '../../../components/LobbyScreen';

const { id } = Astro.params;

// Fetch config from the dynamic worker at /app/[id]
const appUrl = new URL(`/app/${id}`, Astro.url);
const res = await fetch(appUrl.toString());

if (!res.ok) {
  return new Response("Remix not found", { status: 404 });
}

const config = await res.json();
const remixTitle = config.title || "Remix";
---

<PageLayout title={`${remixTitle} — Car Runner`}>
  <LobbyScreen
    remixId={id}
    remixTitle={remixTitle}
    playPath={`/remix/${id}/play`}
    client:only="react"
  />
</PageLayout>
