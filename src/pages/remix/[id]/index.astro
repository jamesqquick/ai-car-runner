---
import { env } from "cloudflare:workers";
import PageLayout from '../../../layouts/PageLayout.astro';
import { LobbyScreen } from '../../../components/LobbyScreen';

const { id } = Astro.params;

// Query D1 directly instead of fetching /app/{id} to avoid self-referential fetch
const remix = await env.DB.prepare(
  "SELECT id, prompt, config FROM remixes WHERE id = ?"
).bind(id).first<{ id: string; prompt: string; config: string }>();

if (!remix) {
  return new Response("Remix not found", { status: 404 });
}

const config = JSON.parse(remix.config);
config.id = remix.id;
config.prompt = remix.prompt;
const remixTitle = config.title || "Remix";
---

<PageLayout title={`${remixTitle} — Car Runner`}>
  <LobbyScreen
    remixId={id}
    remixTitle={remixTitle}
    playPath={`/remix/${id}/play`}
    client:only="react"
  />
</PageLayout>
