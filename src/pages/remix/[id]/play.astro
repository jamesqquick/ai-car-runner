---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { PlayPage } from '../../../components/PlayPage';

const { id } = Astro.params;

// Fetch config from the dynamic worker at /app/[id]
const appUrl = new URL(`/app/${id}`, Astro.url);
const res = await fetch(appUrl.toString());

if (!res.ok) {
  return new Response("Remix not found", { status: 404 });
}

const config = await res.json();
---

<BaseLayout title={`Playing ${config.title || 'Remix'} — Car Runner`} fullScreen>
  <PlayPage
    config={config}
    lobbyPath={`/remix/${id}`}
    client:only="react"
  />
</BaseLayout>
