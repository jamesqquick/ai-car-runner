---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  links?: Array<{ href: string; label: string }>;
  fullScreen?: boolean;
}

const { title, links = [], fullScreen = false } = Astro.props;

const defaultLinks = [
  { href: '/', label: 'Play' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/remix', label: 'Remix' },
  { href: '/spectate', label: 'Spectate' },
];

const navLinks = links.length > 0 ? links : defaultLinks;
---

<BaseLayout title={title} fullScreen={fullScreen}>
  <header class="page-header">
    <a href="/" class="page-header-logo">AI Car Runner</a>

    {/* Desktop nav */}
    <nav class="page-header-links desktop-nav">
      {navLinks.map(link => (
        <a href={link.href} class="page-header-link">{link.label}</a>
      ))}
      <button class="page-header-link logout-btn" aria-label="Log out">Logout</button>
    </nav>

    {/* Mobile hamburger */}
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </header>

  {/* Mobile full-screen overlay */}
  <div class="mobile-nav-overlay" aria-hidden="true">
    <button class="mobile-nav-close" aria-label="Close menu">
      <span class="close-line"></span>
      <span class="close-line"></span>
    </button>
    <nav class="mobile-nav-content">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-nav-link">{link.label}</a>
      ))}
      <button class="mobile-nav-link logout-btn" aria-label="Log out">Logout</button>
    </nav>
  </div>

  <main>
    <slot />
  </main>
</BaseLayout>

<script>
  const hamburger = document.querySelector('.hamburger');
  const overlay = document.querySelector('.mobile-nav-overlay');
  const closeBtn = document.querySelector('.mobile-nav-close');

  function closeNav() {
    overlay?.classList.remove('open');
    hamburger?.classList.remove('open');
    hamburger?.setAttribute('aria-expanded', 'false');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('nav-open');
  }

  function openNav() {
    overlay?.classList.add('open');
    hamburger?.classList.add('open');
    hamburger?.setAttribute('aria-expanded', 'true');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.classList.add('nav-open');
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = overlay?.classList.contains('open');
    isOpen ? closeNav() : openNav();
  });

  closeBtn?.addEventListener('click', closeNav);

  document.querySelectorAll('.logout-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      localStorage.removeItem('car_runner_user');
      localStorage.removeItem('car_runner_commentary');
      window.location.href = '/login';
    });
  });
</script>

<style>
  button.logout-btn.page-header-link {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    margin: 0;
    font-size: 14px;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  button.logout-btn.mobile-nav-link {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text-dim);
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 20px 40px;
    transition: color 0.2s, transform 0.2s;
    transform: translateY(20px);
    opacity: 0;
  }
</style>
