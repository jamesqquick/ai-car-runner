---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  links?: Array<{ href: string; label: string }>;
  fullScreen?: boolean;
}

const { title, links = [], fullScreen = false } = Astro.props;

const defaultLinks = [
  { href: "/", label: "Play" },
  { href: "/leaderboard", label: "High Scores" },
  { href: "/gallery", label: "Gallery" },
  { href: "/remix", label: "Remix" },
  { href: "/spectate", label: "Spectate" },
  { href: "/about", label: "About" },
];

const navLinks = links.length > 0 ? links : defaultLinks;
---

<BaseLayout title={title} fullScreen={fullScreen}>
  <header class="page-header">
    <a href="/" class="page-header-logo">Car Runner</a>

    {/* Desktop nav */}
    <nav class="page-header-links desktop-nav">
      {
        navLinks.map((link) => (
          <a href={link.href} class="page-header-link">
            {link.label}
          </a>
        ))
      }
      <div class="user-dropdown">
        <button
          class="user-dropdown-toggle page-header-link"
          aria-expanded="false"
        >
          <svg
            class="user-avatar"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="8" r="4"></circle>
            <path d="M20 21a8 8 0 1 0-16 0"></path>
          </svg>
          <span class="user-dropdown-name">Account</span>
          <span class="user-dropdown-caret">▾</span>
        </button>
        <div class="user-dropdown-menu">
          <button class="user-dropdown-item logout-btn">Logout</button>
        </div>
      </div>
    </nav>

    {/* Mobile hamburger */}
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </header>

  {/* Mobile full-screen overlay */}
  <div class="mobile-nav-overlay" aria-hidden="true">
    <button class="mobile-nav-close" aria-label="Close menu">
      <span class="close-line"></span>
      <span class="close-line"></span>
    </button>
    <nav class="mobile-nav-content">
      {
        navLinks.map((link) => (
          <a href={link.href} class="mobile-nav-link">
            {link.label}
          </a>
        ))
      }
      <div class="mobile-nav-user"></div>
      <button class="mobile-nav-link logout-btn" aria-label="Log out"
        >Logout</button
      >
    </nav>
  </div>

  <main>
    <slot />
  </main>
</BaseLayout>

<script>
  const hamburger = document.querySelector(".hamburger");
  const overlay = document.querySelector(".mobile-nav-overlay");
  const closeBtn = document.querySelector(".mobile-nav-close");

  function closeNav() {
    overlay?.classList.remove("open");
    hamburger?.classList.remove("open");
    hamburger?.setAttribute("aria-expanded", "false");
    overlay?.setAttribute("aria-hidden", "true");
    document.body.classList.remove("nav-open");
  }

  function openNav() {
    overlay?.classList.add("open");
    hamburger?.classList.add("open");
    hamburger?.setAttribute("aria-expanded", "true");
    overlay?.setAttribute("aria-hidden", "false");
    document.body.classList.add("nav-open");
  }

  hamburger?.addEventListener("click", () => {
    const isOpen = overlay?.classList.contains("open");
    isOpen ? closeNav() : openNav();
  });

  closeBtn?.addEventListener("click", closeNav);

  // Populate user name from localStorage
  try {
    const stored = localStorage.getItem("car_runner_user");
    if (stored) {
      const user = JSON.parse(stored);
      const name = user.name || "Account";
      document.querySelectorAll(".user-dropdown-name").forEach((el) => {
        el.textContent = name;
      });
      const mobileUser = document.querySelector(".mobile-nav-user");
      if (mobileUser) {
        mobileUser.textContent = "";
        const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
        svg.setAttribute("width", "18");
        svg.setAttribute("height", "18");
        svg.setAttribute("viewBox", "0 0 24 24");
        svg.setAttribute("fill", "none");
        svg.setAttribute("stroke", "currentColor");
        svg.setAttribute("stroke-width", "2");
        svg.setAttribute("stroke-linecap", "round");
        svg.setAttribute("stroke-linejoin", "round");
        const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        circle.setAttribute("cx", "12");
        circle.setAttribute("cy", "8");
        circle.setAttribute("r", "4");
        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
        path.setAttribute("d", "M20 21a8 8 0 1 0-16 0");
        svg.appendChild(circle);
        svg.appendChild(path);
        mobileUser.appendChild(svg);
        mobileUser.appendChild(document.createTextNode(" " + name));
      }
    }
  } catch {}

  // Desktop dropdown toggle
  const dropdownToggle = document.querySelector(".user-dropdown-toggle");
  const dropdown = document.querySelector(".user-dropdown");

  dropdownToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = dropdown?.classList.contains("open");
    if (isOpen) {
      dropdown?.classList.remove("open");
      dropdownToggle.setAttribute("aria-expanded", "false");
    } else {
      dropdown?.classList.add("open");
      dropdownToggle.setAttribute("aria-expanded", "true");
    }
  });

  // Close dropdown on outside click
  document.addEventListener("click", () => {
    dropdown?.classList.remove("open");
    dropdownToggle?.setAttribute("aria-expanded", "false");
  });

  // Logout handlers
  document.querySelectorAll(".logout-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      localStorage.removeItem("car_runner_user");
      localStorage.removeItem("car_runner_commentary");
      window.location.href = "/login";
    });
  });
</script>

<style>
  /* Desktop user dropdown */
  .user-dropdown {
    position: relative;
  }
  .user-dropdown-toggle {
    background: var(--color-orange);
    border: none;
    cursor: pointer;
    padding: 6px 14px;
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #000;
    border-radius: 6px;
    transition:
      background 0.2s,
      box-shadow 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .user-avatar {
    flex-shrink: 0;
  }
  .user-dropdown-toggle:hover {
    background: var(--color-orange-light);
    box-shadow: 0 0 16px var(--color-orange-glow);
  }
  .user-dropdown-caret {
    font-size: 11px;
    transition: transform 0.2s;
    opacity: 0.7;
  }
  .user-dropdown.open .user-dropdown-caret {
    transform: rotate(180deg);
  }
  .user-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: rgba(20, 20, 30, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 4px;
    min-width: 120px;
    backdrop-filter: blur(12px);
    z-index: 100;
  }
  .user-dropdown.open .user-dropdown-menu {
    display: block;
  }
  .user-dropdown-item {
    display: block;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-text-dim);
    padding: 8px 12px;
    border-radius: 6px;
    text-align: left;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .user-dropdown-item:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-orange);
  }

  /* Mobile user name label */
  .mobile-nav-user {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-orange);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 12px 40px 4px;
    opacity: 0;
    transform: translateY(20px);
    transition:
      color 0.2s,
      transform 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
  }
  .mobile-nav-overlay.open .mobile-nav-user {
    opacity: 0.7;
    transform: translateY(0);
    transition-delay: 0.25s;
  }

  /* Mobile logout button */
  button.logout-btn.mobile-nav-link {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text-dim);
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 20px 40px;
    transition:
      color 0.2s,
      transform 0.2s,
      opacity 0.2s;
    transform: translateY(20px);
    opacity: 0;
  }
  .mobile-nav-overlay.open button.logout-btn.mobile-nav-link {
    transform: translateY(0);
    opacity: 1;
    transition-delay: 0.3s;
  }
</style>
